pipeline {
    agent any
    environment {
        PROJECT_ID = "spring-bookstore-dev"
        REGION = "us-central1"
        REPO_NAME = "my-docker-repo"
        DOCKER_REGISTRY = "${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPO_NAME}"
        SERVICES = "config-server discovery-server api-gateway book-service author-service order-service stock-check-service message-service"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Compile Java Code (Maven)') {
            steps {
                // This step is mandatory! It creates the .jar files the Dockerfiles need.
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Authenticate to Google Cloud') {
            steps {
                // Safely uses the secret file we uploaded to Jenkins earlier
                withCredentials([file(credentialsId: 'gcp-key', variable: 'GCP_SECRET_FILE')]) {
                    sh '''
                    # Added quotes around the variables to protect against spaces in folder names!
                    gcloud auth activate-service-account --key-file="$GCP_SECRET_FILE"
                    gcloud config set project "$PROJECT_ID"
                    gcloud auth configure-docker "$REGION"-docker.pkg.dev --quiet
                    '''
                }
            }
        }

        stage('Build and Push Java Microservices') {
            steps {
                script {
                    def serviceList = SERVICES.split(' ')
                    for (service in serviceList) {
                        echo "Building ${service}..."
                        dir("${service}") {
                            def imageTag = "${DOCKER_REGISTRY}/${service}:${env.BUILD_NUMBER}"
                            sh "docker build -t ${imageTag} ."
                            sh "docker push ${imageTag}"
                        }
                    }
                }
            }
        }

        stage('Build and Push Frontend') {
            steps {
                dir('frontend') {
                    script {
                        def imageTag = "${DOCKER_REGISTRY}/frontend:${env.BUILD_NUMBER}"
                        sh "docker build -t ${imageTag} ."
                        sh "docker push ${imageTag}"
                    }
                }
            }
        }
    }
}
