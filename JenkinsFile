pipeline {
    agent any
    environment {
        // --- GOOGLE CLOUD SETTINGS ---
        PROJECT_ID = "spring-bookstore-dev"
        REGION = "us-central1"
        REPO_NAME = "my-docker-repo"
        DOCKER_REGISTRY = "${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPO_NAME}"
        
        // --- KUBERNETES SETTINGS ---
        CLUSTER_NAME = "shyam-private-gke" 
        CLUSTER_ZONE = "us-central1-a"
        
        // --- MICROSERVICES ---
        SERVICES = "config-server discovery-server api-gateway book-service author-service order-service stock-check-service message-service"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Compile Java Code (Maven)') {
            steps {
                // Skips tests and skips the Jib plugin to prevent Docker Hub rate limits
                sh 'mvn clean package -DskipTests -Djib.skip=true'
            }
        }

        stage('Authenticate to Google Cloud') {
            steps {
                withCredentials([file(credentialsId: 'gcp-key', variable: 'GCP_SECRET_FILE')]) {
                    sh '''
                    gcloud auth activate-service-account --key-file="$GCP_SECRET_FILE"
                    gcloud config set project "$PROJECT_ID"
                    gcloud auth configure-docker "$REGION"-docker.pkg.dev --quiet
                    '''
                }
            }
        }

        stage('Build and Push Java Microservices') {
            steps {
                script {
                    def serviceList = SERVICES.split(' ')
                    for (service in serviceList) {
                        echo "Building ${service}..."
                        dir("${service}") {
                            // Automatically generates the Java Dockerfile
                            writeFile file: 'Dockerfile', text: '''
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
ARG JAR_FILE=target/*.jar
COPY ${JAR_FILE} app.jar
ENTRYPOINT ["java","-jar","/app/app.jar"]
'''
                            // Create both the specific build tag AND the 'latest' tag
                            def imageTag = "${DOCKER_REGISTRY}/${service}:${env.BUILD_NUMBER}"
                            def latestTag = "${DOCKER_REGISTRY}/${service}:latest"
                            
                            // Build and push the specific version
                            sh "docker build -t ${imageTag} ."
                            sh "docker push ${imageTag}"
                            
                            // Tag and push as 'latest' so Kubernetes can easily find it
                            sh "docker tag ${imageTag} ${latestTag}"
                            sh "docker push ${latestTag}"
                        }
                    }
                }
            }
        }

        stage('Build and Push Frontend') {
            steps {
                dir('frontend') {
                    script {
                        // Automatically generates the Next.js Dockerfile
                        writeFile file: 'Dockerfile', text: '''
FROM node:18-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build
EXPOSE 3000
CMD ["npm", "start"]
'''
                        // Create both the specific build tag AND the 'latest' tag
                        def imageTag = "${DOCKER_REGISTRY}/frontend:${env.BUILD_NUMBER}"
                        def latestTag = "${DOCKER_REGISTRY}/frontend:latest"
                        
                        // Build and push the specific version
                        sh "docker build -t ${imageTag} ."
                        sh "docker push ${imageTag}"
                        
                        // Tag and push as 'latest'
                        sh "docker tag ${imageTag} ${latestTag}"
                        sh "docker push ${latestTag}"
                    }
                }
            }
        }

        stage('Deploy to Kubernetes (GKE)') {
            steps {
                withCredentials([file(credentialsId: 'gcp-key', variable: 'GCP_SECRET_FILE')]) {
                    sh '''
                    # 1. Connect Jenkins to your specific GKE Cluster
                    gcloud container clusters get-credentials "shyam-private-gke" --zone "us-central1-a" --project "$PROJECT_ID"
                    
                    # 2. Apply all Kubernetes YAML configurations (recursively searching subfolders)
                    kubectl apply -R -f kubernetes/
                    
                    # 3. Tell Kubernetes to forcefully restart to pull your brand new images!
                    kubectl rollout restart deployment
                    '''
                }
            }
        }
    }
}
