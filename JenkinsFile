pipeline {
    agent any
    environment {
        // --- GOOGLE CLOUD SETTINGS ---
        PROJECT_ID = "spring-bookstore-dev"
        REGION = "us-central1"
        REPO_NAME = "my-docker-repo"
        DOCKER_REGISTRY = "${REGION}-docker.pkg.dev/${PROJECT_ID}/${REPO_NAME}"
        
        // --- KUBERNETES SETTINGS ---
        // (Update these with your actual GKE cluster name and zone!)
        CLUSTER_NAME = "my-cluster" 
        CLUSTER_ZONE = "us-central1-a"
        
        // --- MICROSERVICES ---
        SERVICES = "config-server discovery-server api-gateway book-service author-service order-service stock-check-service message-service"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Compile Java Code (Maven)') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Authenticate to Google Cloud') {
            steps {
                withCredentials([file(credentialsId: 'gcp-key', variable: 'GCP_SECRET_FILE')]) {
                    sh '''
                    gcloud auth activate-service-account --key-file="$GCP_SECRET_FILE"
                    gcloud config set project "$PROJECT_ID"
                    gcloud auth configure-docker "$REGION"-docker.pkg.dev --quiet
                    '''
                }
            }
        }

        stage('Build and Push Java Microservices') {
            steps {
                script {
                    def serviceList = SERVICES.split(' ')
                    for (service in serviceList) {
                        echo "Building ${service}..."
                        dir("${service}") {
                            writeFile file: 'Dockerfile', text: '''
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
ARG JAR_FILE=target/*.jar
COPY ${JAR_FILE} app.jar
ENTRYPOINT ["java","-jar","/app/app.jar"]
'''
                            def imageTag = "${DOCKER_REGISTRY}/${service}:${env.BUILD_NUMBER}"
                            sh "docker build -t ${imageTag} ."
                            sh "docker push ${imageTag}"
                        }
                    }
                }
            }
        }

        stage('Build and Push Frontend') {
            steps {
                dir('frontend') {
                    script {
                        writeFile file: 'Dockerfile', text: '''
FROM node:18-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build
EXPOSE 3000
CMD ["npm", "start"]
'''
                        def imageTag = "${DOCKER_REGISTRY}/frontend:${env.BUILD_NUMBER}"
                        sh "docker build -t ${imageTag} ."
                        sh "docker push ${imageTag}"
                    }
                }
            }
        }

        // =========================================================
        // NEW STAGE: CONTINUOUS DEPLOYMENT (CD) TO KUBERNETES
        // =========================================================
        stage('Deploy to Kubernetes (GKE)') {
            steps {
                withCredentials([file(credentialsId: 'gcp-key', variable: 'GCP_SECRET_FILE')]) {
                    sh '''
                    # 1. Connect Jenkins to your specific GKE Cluster
                    gcloud container clusters get-credentials "$CLUSTER_NAME" --zone "$CLUSTER_ZONE" --project "$PROJECT_ID"
                    
                    # 2. Apply all Kubernetes YAML configurations from your 'kubernetes' folder
                    kubectl apply -f kubernetes/
                    
                    # 3. Tell Kubernetes to forcefully restart to pull your brand new images!
                    kubectl rollout restart deployment
                    '''
                }
            }
        }
    }
}
